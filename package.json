{
  "name": "cloudtab",
  "version": "0.1.0",
  "description": "One-command secure remote Chrome browser on GCP",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE ELECTRON_EXTRA_LAUNCH_ARGS='--no-sandbox --disable-setuid-sandbox --disable-gpu-sandbox' electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:win": "electron-vite build && electron-builder --win",
    "package:all": "electron-vite build && electron-builder --mac --linux --win",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.cloudtab.app",
    "productName": "CloudTab",
    "directories": {
      "buildResources": "src/assets",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "core",
        "to": "core",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "pkzhang666",
      "repo": "cloudtab-desktop"
    }
  }
}
