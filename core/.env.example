# ── GCP settings (read by scripts/setup.sh → generates terraform/terraform.tfvars) ──
PROJECT_ID=your-gcp-project-id
REGION=us-central1
ZONE=us-central1-a
VM_NAME=novnc-chrome
MACHINE_TYPE=e2-standard-2
DISK_SIZE_GB=50
PREEMPTIBLE=false
SUBNET_CIDR=10.0.0.0/24    # change if this conflicts with existing VPC peering

# ── noVNC / VNC settings ─────────────────────────────────────────────────────
# VNC_PASSWORD must be at least 8 characters. 'changeme' is rejected.
VNC_PASSWORD=changeme

# Virtual display resolution (WxHxBitDepth).
# RESOLUTION_WIDTH and RESOLUTION_HEIGHT are derived automatically — do not set them.
RESOLUTION=1920x1080x24

# Extra pixels added to display height to avoid bottom clipping (workspace/taskbar).
EXTRA_HEIGHT_PX=30

# Preferred vertical offset for the Chrome window inside the virtual display.
# Helps avoid top clipping; defaults to 30.
WINDOW_OFFSET_Y=30

# Preferred local port for the IAP tunnel (CloudTab auto-selects a nearby free port if busy).
LOCAL_TUNNEL_PORT=8080
